{
  "manifest_version": 3,
  "name": "Mail Style AI (MVP)",
  "version": "0.0.1",
  "description": "Исправить ошибки + деловой/вежливый стиль + подумать. MVP.",
  "permissions": ["storage"],
  "host_permissions": ["https://api.deepseek.com/*"],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}
